#!/usr/bin/env bash
# Seeds Prometheus with synthetic uptime data for development, then
# aggregates it into Upright::Rollups::ProbeRollup.
#
# Generates 90 days of daily uptime and 2 hours of raw probe status data.
#
# Prerequisites: docker with the upright-prometheus container running.
#
# Usage: bin/seed-prometheus

set -euo pipefail

CONTAINER="upright-prometheus"
TMPFILE=$(mktemp /tmp/upright-seed-XXXXXX.om)
trap 'rm -f "$TMPFILE"' EXIT

NOW=$(date +%s)
# DailyAggregationJob queries upright:probe_uptime_daily at day.end_of_day (UTC),
# and Prometheus only returns samples within 5 minutes of the query time. Anchor
# each day's sample at 23:59 UTC so the job actually finds it; today is clamped
# to NOW since Prometheus rejects future samples.
TODAY_END_UTC=$(TZ=UTC date -d "today 23:59:00" +%s)

# Probes: name|type|target|service (must match test/dummy/probes/*.yml)
PROBES=(
  "Example|http|https://example.com/|example_app"
  "Expected301|http|https://example.com/redirect|example_app"
  "MultiProxy|http|https://example.com/multi|example_app"
  "Gmail|smtp|smtp.gmail.com|internal_tools"
  "Google DNS|traceroute|8.8.8.8|internal_tools"
  "Cloudflare DNS|traceroute|1.1.1.1|internal_tools"
)

# Sites: code|city|country|geohash|provider (must match config/sites.yml)
SITES=(
  "ams|Amsterdam|NL|u17982|digitalocean"
  "nyc|New York City|US|dr5reg|digitalocean"
  "sfo|San Francisco|US|9q8yy|digitalocean"
)

echo "Generating seed data..."

{
  # === upright:probe_uptime_daily ===
  # Used by the Uptime Dashboard (30-day view, 1-day resolution), the public
  # status page (90-day window), and the ProbeRollup aggregation job. Normally
  # a recording rule writes this, but rules don't backfill so we emit it.
  echo '# TYPE upright:probe_uptime_daily gauge'
  echo '# HELP upright:probe_uptime_daily Daily uptime percentage'

  # Days (ago) that simulate cross-probe incidents so the bars show all statuses
  # and the service rollup (min across probes) clearly reflects them.
  MAJOR_INCIDENT_DAY=22
  PARTIAL_INCIDENT_DAY=12

  for ((day = 89; day >= 0; day--)); do
    ts=$((TODAY_END_UTC - day * 86400))
    (( ts > NOW )) && ts=$NOW
    for probe in "${PROBES[@]}"; do
      IFS='|' read -r pname ptype ptarget pservice <<< "$probe"

      uptime=""
      if (( day == MAJOR_INCIDENT_DAY )) && [[ "$pname" == "MultiProxy" ]]; then
        uptime="0.40"  # major_outage
      elif (( day == PARTIAL_INCIDENT_DAY )) && [[ "$pname" == "Gmail" ]]; then
        uptime="0.78"  # partial_outage
      fi

      if [[ -z "$uptime" ]]; then
        r=$((RANDOM % 100))
        case "$pname" in
          MultiProxy)
            # Flakiest probe — sample touches every status tier
            if   (( r < 50 )); then uptime="1.0"
            elif (( r < 75 )); then uptime="0.97"  # degraded
            elif (( r < 92 )); then uptime="0.82"  # partial_outage
            else                     uptime="0.45" # major_outage
            fi ;;
          Gmail)
            # Occasionally partial to colour the internal_tools service
            if   (( r < 70 )); then uptime="1.0"
            elif (( r < 90 )); then uptime="0.97"
            elif (( r < 98 )); then uptime="0.85"
            else                     uptime="0.55"
            fi ;;
          *)
            # Mostly reliable, occasional minor blips
            if   (( r < 90 )); then uptime="1.0"
            elif (( r < 98 )); then uptime="0.99"
            else                     uptime="0.95"
            fi ;;
        esac
      fi

      echo "upright:probe_uptime_daily{name=\"${pname}\",type=\"${ptype}\",probe_target=\"${ptarget}\",probe_service=\"${pservice}\",environment=\"development\"} ${uptime} ${ts}.0"
    done
  done

  # === upright_probe_up ===
  # Used by the Probe Status Dashboard (30-min view, 30s resolution).
  # We generate 2 hours so there's data even if the app hasn't been running.
  echo '# TYPE upright_probe_up gauge'
  echo '# HELP upright_probe_up Probe status (1 = up, 0 = down)'

  for ((ts = NOW - 7200; ts <= NOW; ts += 30)); do
    for probe in "${PROBES[@]}"; do
      IFS='|' read -r pname ptype ptarget pservice <<< "$probe"
      for site in "${SITES[@]}"; do
        IFS='|' read -r scode scity scountry sgeohash sprovider <<< "$site"

        val=1
        # MultiProxy is flaky at ams to give the status matrix something to show
        if [[ "$pname" == "MultiProxy" && "$scode" == "ams" ]]; then
          if (( RANDOM % 100 < 8 )); then val=0; fi
        elif (( RANDOM % 100 < 2 )); then
          val=0
        fi

        echo "upright_probe_up{name=\"${pname}\",type=\"${ptype}\",probe_target=\"${ptarget}\",probe_service=\"${pservice}\",alert_severity=\"high\",site_code=\"${scode}\",site_city=\"${scity}\",site_country=\"${scountry}\",site_geohash=\"${sgeohash}\",site_provider=\"${sprovider}\",environment=\"development\"} ${val}.0 ${ts}.0"
      done
    done
  done

  echo '# EOF'
} > "$TMPFILE"

lines=$(wc -l < "$TMPFILE")
echo "Generated ${lines} lines of metric data."

echo "Importing into Prometheus..."
chmod 644 "$TMPFILE"
docker cp "$TMPFILE" "${CONTAINER}:/tmp/seed-data.om"
docker exec "$CONTAINER" promtool tsdb create-blocks-from openmetrics /tmp/seed-data.om /tmp/seed-blocks
docker exec "$CONTAINER" sh -c 'cp -r /tmp/seed-blocks/* /prometheus/'
docker exec --user root "$CONTAINER" rm -rf /tmp/seed-blocks /tmp/seed-data.om
curl -sf -X POST http://localhost:9090/-/reload

# Reload is async — Prometheus loads blocks in the background, oldest last.
# Wait until the OLDEST seeded day is queryable, otherwise the aggregation
# job races ahead and silently produces partial rollups.
echo "Waiting for Prometheus to load new blocks..."
OLDEST_TS=$((TODAY_END_UTC - 89 * 86400))
deadline=$((SECONDS + 60))
until curl -sfG http://localhost:9090/api/v1/query \
    --data-urlencode 'query=count(upright:probe_uptime_daily)' \
    --data-urlencode "time=$((OLDEST_TS + 59))" \
    | grep -q '"value":\[.*,"[1-9]'; do
  (( SECONDS > deadline )) && { echo "Timed out waiting for Prometheus."; exit 1; }
  sleep 1
done

echo "Seeded 90 days of uptime data for ${#PROBES[@]} probes across ${#SITES[@]} sites."

echo "Aggregating ProbeRollup from Prometheus..."
ENGINE_ROOT=$(cd "$(dirname "$0")/../../.." && pwd)
cd "$ENGINE_ROOT"
bin/rails runner 'Upright::Rollups::DailyAggregationJob.new.perform(past: 90.days)'

echo "Done."
