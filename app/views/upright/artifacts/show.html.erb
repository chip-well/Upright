<%= turbo_frame_tag dom_id(@artifact) do %>
  <% if @artifact.video? %>
    <video controls width="960" preload="none" autoplay muted>
      <source src="<%= main_app.rails_blob_path(@artifact, disposition: :inline) %>" type="video/webm">
    </video>
  <% elsif @artifact.filename.to_s.end_with?(".zip") %>
    <% blob_url = main_app.rails_blob_url(@artifact, disposition: :attachment, expires_in: 24.hours) %>
    <div class="artifact__trace">
      <a href="https://trace.playwright.dev/?trace=<%= CGI.escape(blob_url) %>" target="_blank" rel="noopener">
        Open in Playwright Trace Viewer ↗
      </a>
    </div>
  <% else %>
    <pre><%= @artifact.download %></pre>
  <% end %>
<% end %>
